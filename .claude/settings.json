{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/mijgonaazizzoda/GolandProjects/test-claude-team/salon-flow && go vet ./... 2>&1 | head -30"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[salon-flow] Running: '$CLAUDE_TOOL_INPUT_COMMAND 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(make *)",
      "Bash(psql *)",
      "Bash(golangci-lint *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  }
}